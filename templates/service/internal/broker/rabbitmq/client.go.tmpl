package rabbitmq

import (
	"log/slog"

	amqp "github.com/rabbitmq/amqp091-go"
	"{{.ModulePath}}/internal/config"
)

type Client struct {
	conn    *amqp.Connection
	channel *amqp.Channel
	log     *slog.Logger
}

func NewClient(cfg *config.Config, log *slog.Logger) (*Client, error) {
	url := cfg.BrokerURL
	if url == "" {
		url = "amqp://guest:guest@localhost:5672/"
	}

	conn, err := amqp.Dial(url)
	if err != nil {
		return nil, err
	}

	ch, err := conn.Channel()
	if err != nil {
		conn.Close()
		return nil, err
	}

	log.Info("connected to RabbitMQ", "url", url)

	return &Client{
		conn:    conn,
		channel: ch,
		log:     log,
	}, nil
}

func (c *Client) Channel() *amqp.Channel {
	return c.channel
}

func (c *Client) Close() error {
	c.log.Info("closing RabbitMQ connection")
	c.channel.Close()
	return c.conn.Close()
}
