package kafka

import (
	"log/slog"

	"{{.ModulePath}}/internal/config"
)

// Client represents a dummy Kafka connection.
type Client struct {
	log *slog.Logger
}

// NewClient initializes a connection to Kafka.
func NewClient(cfg *config.Config, log *slog.Logger) (*Client, error) {
	log.Info("connecting to Kafka", "broker", "localhost:9092")
	return &Client{log: log}, nil
}

// Close closes the Kafka connection.
func (c *Client) Close() error {
	c.log.Info("closing Kafka connection")
	return nil
}
